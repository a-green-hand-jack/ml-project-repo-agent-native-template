# Codex execpolicy rules for this repo.
# Hook scripts remain the safety floor; these rules provide the prompt/deny layer.

prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "Privilege escalation is forbidden by .agent/action-boundary.md.",
)

prefix_rule(
    pattern = ["pip", "install"],
    decision = "forbidden",
    justification = "Use `uv add` instead of pip install so dependency changes are reviewable.",
)

prefix_rule(
    pattern = ["pip3", "install"],
    decision = "forbidden",
    justification = "Use `uv add` instead of pip install so dependency changes are reviewable.",
)

prefix_rule(
    pattern = [["python", "python3"], "-m", "pip", "install"],
    decision = "forbidden",
    justification = "Use `uv add` instead of python -m pip install.",
)

prefix_rule(
    pattern = ["git", ["checkout", "switch", "reset", "clean", "rebase", "merge"]],
    decision = "prompt",
    justification = "History or worktree-changing git commands need human awareness.",
)

prefix_rule(
    pattern = ["git", "branch", ["-d", "-D"]],
    decision = "prompt",
    justification = "Deleting branches needs confirmation.",
)

prefix_rule(
    pattern = ["git", "worktree", "remove"],
    decision = "prompt",
    justification = "Removing worktrees needs confirmation.",
)

prefix_rule(
    pattern = ["uv", ["add", "sync", "remove"]],
    decision = "prompt",
    justification = "Dependency/environment changes need confirmation.",
)

prefix_rule(
    pattern = [["kill", "sbatch", "runai"]],
    decision = "prompt",
    justification = "Compute side effects need human approval.",
)

prefix_rule(
    pattern = [["scancel", "srun"]],
    decision = "prompt",
    justification = "Slurm job control/launch side effects need human approval (launch registry, issue #16).",
)

prefix_rule(
    pattern = [["python", "python3"], "lab/infra/launch/fake_job.py", ["launch", "kill", "restart"]],
    decision = "prompt",
    justification = "Registered launch-registry entry (lab/infra/launch/registry.yaml): launch/kill/restart are human gates even for the local fake backend.",
)

prefix_rule(
    pattern = [["python", "python3"], "lab/infra/launch/expctl.py", "apply-recovery"],
    decision = "prompt",
    justification = "Registered launch-registry entry: recovery validation is gated and actual execution is fail-closed until trusted provenance plus atomic consumption exist.",
)

# Wrapper 变体加宽（issue #16 Codex 初审 BLOCKER-1）：静态前缀只能覆盖有限包装形态
# （env/nohup/nice/setsid/stdbuf 直接包一层、python -u）；带参数的 wrapper（timeout 60、
# nice -n 10）与更深组合由共享 pre_tool_guard 地板（launch_gate.py 的 wrapper 剥离）兜底。
prefix_rule(
    pattern = [["env", "nohup", "nice", "setsid", "stdbuf"], ["sbatch", "scancel", "srun", "runai"]],
    decision = "prompt",
    justification = "Wrapped scheduler commands are still compute side effects (launch registry, issue #16); deeper wrapper variants are caught by the shared pre_tool_guard floor.",
)

prefix_rule(
    pattern = ["env", ["python", "python3"], "lab/infra/launch/fake_job.py", ["launch", "kill", "restart"]],
    decision = "prompt",
    justification = "env-wrapped launch-registry entry: still a human gate.",
)

prefix_rule(
    pattern = [["python", "python3"], "-u", "lab/infra/launch/fake_job.py", ["launch", "kill", "restart"]],
    decision = "prompt",
    justification = "python -u variant of a launch-registry entry: still a human gate.",
)

prefix_rule(
    pattern = ["env", ["python", "python3"], "lab/infra/launch/expctl.py", "apply-recovery"],
    decision = "prompt",
    justification = "env-wrapped launch-registry entry: still a human gate.",
)

prefix_rule(
    pattern = [["python", "python3"], "-u", "lab/infra/launch/expctl.py", "apply-recovery"],
    decision = "prompt",
    justification = "python -u variant of a launch-registry entry: still a human gate.",
)

prefix_rule(
    pattern = ["env", ["python", "python3"], "-u", "lab/infra/launch/fake_job.py", ["launch", "kill", "restart"]],
    decision = "prompt",
    justification = "env + python -u variant of a launch-registry entry: still a human gate.",
)

prefix_rule(
    pattern = ["env", ["python", "python3"], "-u", "lab/infra/launch/expctl.py", "apply-recovery"],
    decision = "prompt",
    justification = "env + python -u variant of a launch-registry entry: still a human gate.",
)

# Caller-controlled env assignments are never human approval. These broad
# wrapper/eval rules keep nested launch attempts at the Codex prompt layer;
# the shared hook additionally parses their inner command and denies it.
prefix_rule(
    pattern = [["env", "/usr/bin/env"]],
    decision = "prompt",
    justification = "env can add caller-controlled assignments or hide dynamic command parsing; the hook remains the non-overridable launch floor.",
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["-S", "--split-string"]],
    decision = "prompt",
    justification = "env split-string can hide a launch command; caller-controlled environment is not approval.",
)

prefix_rule(
    pattern = [["env", "/usr/bin/env"], ["CLAUDE_ALLOW_LAUNCH=1", "CODEX_ALLOW_LAUNCH=1"]],
    decision = "prompt",
    justification = "CLAUDE/CODEX_ALLOW_LAUNCH are caller-forgeable and never bypass the launch gate.",
)

prefix_rule(
    pattern = [["CLAUDE_ALLOW_LAUNCH=1", "CODEX_ALLOW_LAUNCH=1"]],
    decision = "prompt",
    justification = "Direct caller-controlled launch env assignments are not human approval and never bypass the hook.",
)

prefix_rule(
    pattern = [["bash", "/bin/bash", "sh", "/bin/sh", "zsh", "/bin/zsh", "dash", "/bin/dash"], ["-c", "-lc"]],
    decision = "prompt",
    justification = "Shell eval can hide a launch command; the shared hook fails this dynamic surface closed.",
)

prefix_rule(
    pattern = [["nohup", "nice", "setsid", "stdbuf", "timeout", "command", "exec", "ionice"], ["bash", "/bin/bash", "sh", "/bin/sh", "zsh", "/bin/zsh", "dash", "/bin/dash"]],
    decision = "prompt",
    justification = "A wrapped shell evaluator is still a dynamic execution surface; the hook fails it closed.",
)

prefix_rule(
    pattern = [["python", "python3"], "-c"],
    decision = "prompt",
    justification = "Dynamic Python evaluation can create compute side effects and needs human review.",
)

prefix_rule(
    pattern = ["gh", "pr", ["create", "merge"]],
    decision = "prompt",
    justification = "PR creation/merge is an external collaboration side effect.",
)

prefix_rule(
    pattern = [["rg", "ls", "pwd", "cat", "sed", "head", "tail", "wc", "stat", "find"]],
    decision = "allow",
    justification = "Low-risk local inspection commands.",
)

prefix_rule(
    pattern = ["git", ["status", "diff", "log", "show", "branch", "remote", "rev-parse", "ls-files", "blame", "fetch", "worktree"]],
    decision = "allow",
    justification = "Low-risk git inspection commands; hook still guards protected pushes and destructive paths.",
)

prefix_rule(
    pattern = [["python", "python3"], "scripts/validate-governance.py"],
    decision = "allow",
    justification = "Repo governance validator.",
)

prefix_rule(
    pattern = [["python", "python3"], "scripts/check-agent-harness.py"],
    decision = "allow",
    justification = "Repo harness validator.",
)

prefix_rule(
    pattern = [["python", "python3"], "scripts/check-anatomy-drift.py"],
    decision = "allow",
    justification = "Repo anatomy validator.",
)

prefix_rule(
    pattern = [["python", "python3"], "scripts/sync-codex-adapters.py"],
    decision = "allow",
    justification = "Regenerates checked-in Codex adapter files from canonical .claude sources.",
)
