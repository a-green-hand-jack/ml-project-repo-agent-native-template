!lab/data/checksums/
!lab/data/checksums/**
!lab/data/task-sets/
!lab/data/task-sets/**
!lab/data/schemas/
!lab/data/schemas/**
!lab/data/**/.gitkeep

# checkpoints / 模型权重 bytes（保留 index yaml）
lab/models/**
!lab/models/
!lab/models/*.yaml
!lab/models/README.md
!lab/models/ANATOMY.md
!lab/models/.gitkeep
checkpoints/
*.ckpt
*.pt
*.pth
*.safetensors

# 实验追踪
wandb/
mlruns/
outputs/
logs/

