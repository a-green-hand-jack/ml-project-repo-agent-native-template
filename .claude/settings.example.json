{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "扩展示例：在 settings.json 基础上加入可选 hooks。按项目真实工具裁剪后复制进 settings.json。",
  "permissions": {
    "deny": [
      "Agent(general-purpose)",
      "Bash(rm -rf *)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(gh pr create *)",
      "Bash(gh pr merge *)"
    ],
    "allow": [
      "Bash(pytest *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/pre_tool_guard.py" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "_comment": "编辑 Python 后自动格式化。需要项目已装 ruff。",
        "hooks": [
          { "type": "command", "command": "ruff format $CLAUDE_FILE_PATHS 2>/dev/null || true" }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/pre_compact_memory_check.py" }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "*",
        "_comment": "Claude 等待输入/权限时通知（按需接入桌面通知命令）。",
        "hooks": [
          { "type": "command", "command": "true" }
        ]
      }
    ]
  }
}
